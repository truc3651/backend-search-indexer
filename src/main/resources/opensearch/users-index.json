{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 1,
    "analysis": {
      "analyzer": {
        "content_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "stop", "snowball"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id": { "type": "long" },
      "fullName": {
        "type": "text",
        "analyzer": "content_analyzer"
      },
      "createdAt": { "type": "date", "index": false },
      "updatedAt": { "type": "date", "index": false }
    }
  }
}
